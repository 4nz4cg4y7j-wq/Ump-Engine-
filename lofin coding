<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Officials Engine | Login</title>

  <style>
    :root {
      --bg: #020913;
      --panel: #061a2d;
      --line: rgba(134, 188, 255, 0.32);
      --text: #f7fbff;
      --muted: #d9e6f7;
      --blue: #2478ff;
      --blue-2: #0f58d9;
      --green: #57d980;
      --danger: #ff6b6b;
      --shadow: 0 24px 80px rgba(0, 0, 0, 0.44);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: Inter, system-ui, Arial, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 20% 0%, rgba(36, 120, 255, 0.2), transparent 35rem),
        radial-gradient(circle at 90% 20%, rgba(87, 217, 128, 0.1), transparent 26rem),
        var(--bg);
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    header {
      border-bottom: 1px solid rgba(100, 164, 255, 0.12);
      background: rgba(2, 9, 19, 0.85);
      backdrop-filter: blur(10px);
    }

    .nav {
      width: min(100% - 40px, 1200px);
      min-height: 96px;
      margin: auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
    }

    .logo {
      font-weight: 800;
      letter-spacing: 1px;
      font-size: 1.4rem;
    }

    .logo span {
      color: var(--blue);
    }

    .menu {
      display: flex;
      align-items: center;
      gap: clamp(16px, 2.4vw, 34px);
      margin-left: auto;
      color: rgba(255, 255, 255, 0.9);
      font-weight: 600;
    }

    .menu a:hover,
    .menu a.active {
      color: var(--blue);
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0 20px;
      border-radius: 8px;
      border: 1px solid transparent;
      color: #fff;
      font-weight: 800;
      background: linear-gradient(180deg, var(--blue), var(--blue-2));
      box-shadow: 0 14px 30px rgba(36, 120, 255, 0.25);
      cursor: pointer;
      white-space: nowrap;
    }

    .btn.outline {
      background: rgba(2, 9, 19, 0.45);
      border-color: rgba(255, 255, 255, 0.7);
      box-shadow: none;
    }

    main {
      width: min(100% - 40px, 1120px);
      min-height: calc(100vh - 97px);
      margin: auto;
      display: grid;
      grid-template-columns: minmax(0, 0.95fr) minmax(340px, 0.7fr);
      align-items: center;
      gap: 56px;
      padding: 56px 0;
    }

    .copy h1 {
      margin: 0 0 16px;
      font-size: clamp(2.4rem, 5vw, 4.2rem);
      line-height: 1.05;
      text-transform: uppercase;
    }

    .copy h1 span {
      color: var(--blue);
    }

    .copy p {
      max-width: 560px;
      margin: 0;
      color: var(--muted);
      font-size: 1.15rem;
      line-height: 1.55;
    }

    .auth-card {
      padding: 30px;
      border: 1px solid var(--line);
      border-radius: 14px;
      background:
        linear-gradient(145deg, rgba(22, 58, 98, 0.44), rgba(3, 13, 27, 0.92)),
        var(--panel);
      box-shadow: var(--shadow);
    }

    .auth-card h2 {
      margin: 0 0 8px;
      font-size: 1.8rem;
    }

    .auth-card > p {
      margin: 0 0 24px;
      color: var(--muted);
      line-height: 1.45;
    }

    form {
      display: grid;
      gap: 16px;
    }

    label {
      display: grid;
      gap: 8px;
      color: #fff;
      font-weight: 700;
    }

    input {
      width: 100%;
      min-height: 50px;
      padding: 0 14px;
      border: 1px solid rgba(134, 188, 255, 0.28);
      border-radius: 8px;
      color: #fff;
      background: rgba(2, 9, 19, 0.7);
      font: inherit;
      outline: none;
    }

    input:focus {
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(36, 120, 255, 0.18);
    }

    .row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      color: var(--muted);
      font-size: 0.95rem;
    }

    .row label {
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 600;
    }

    input[type="checkbox"] {
      width: 18px;
      min-height: 18px;
      accent-color: var(--blue);
    }

    .link {
      color: #8fc2ff;
      font-weight: 800;
      background: none;
      border: 0;
      padding: 0;
      cursor: pointer;
    }

    .message {
      display: none;
      padding: 12px 14px;
      border-radius: 8px;
      line-height: 1.35;
      font-weight: 700;
    }

    .message.error {
      display: block;
      color: #fff;
      border: 1px solid rgba(255, 107, 107, 0.45);
      background: rgba(255, 107, 107, 0.13);
    }

    .message.success {
      display: block;
      color: #fff;
      border: 1px solid rgba(87, 217, 128, 0.45);
      background: rgba(87, 217, 128, 0.13);
    }

    .switch {
      margin: 22px 0 0;
      color: var(--muted);
      text-align: center;
    }

    .master-mode {
      margin-top: 24px;
      padding-top: 24px;
      border-top: 1px solid rgba(134, 188, 255, 0.18);
    }

    .master-mode h3 {
      margin: 0 0 8px;
      text-transform: uppercase;
    }

    .master-mode p {
      margin: 0 0 16px;
      color: var(--muted);
      line-height: 1.45;
    }

    @media (max-width: 900px) {
      .nav {
        flex-direction: column;
        padding: 20px 0;
      }

      .menu {
        margin-left: 0;
        flex-wrap: wrap;
        justify-content: center;
      }

      main {
        grid-template-columns: 1fr;
        text-align: center;
      }

      .copy p {
        margin: auto;
      }

      .row {
        align-items: flex-start;
        flex-direction: column;
      }
    }
  </style>
</head>

<body>
  <header>
    <div class="nav">
      <a class="logo" href="index.html">Officials <span>Engine</span></a>
      <nav class="menu" aria-label="Main navigation">
        <a href="index.html">Home</a>
        <a href="index.html#features">Features</a>
        <a href="pricing.html">Pricing</a>
        <a href="index.html#plans">How It Works</a>
        <a href="index.html#about">About Us</a>
      </nav>
      <a class="btn" href="register.html">Get Started</a>
    </div>
  </header>

  <main>
    <section class="copy">
      <h1>Welcome Back To <span>Officials Engine</span></h1>
      <p>
        Sign in to manage assignments, schedules, officials, and game-day updates from one organized workspace.
      </p>
    </section>

    <section class="auth-card" aria-labelledby="login-title">
      <h2 id="login-title">Login</h2>
      <p>Use the email and password you registered with.</p>
      <div id="message" class="message" aria-live="polite"></div>

      <form id="loginForm">
        <label>
          Email
          <input id="email" type="email" autocomplete="email" required />
        </label>

        <label>
          Password
          <input id="password" type="password" autocomplete="current-password" required />
        </label>

        <div class="row">
          <label>
            <input id="remember" type="checkbox" />
            Remember me
          </label>
          <button class="link" type="button" id="forgotPassword">Forgot password?</button>
        </div>

        <button class="btn" type="submit">Login</button>
      </form>

      <p class="switch">Need an account? <a class="link" href="register.html">Create one</a></p>

      <div class="master-mode">
        <h3>Master Mode</h3>
        <p>Use your private master code to go straight to the dashboard.</p>
        <form id="masterForm">
          <label>
            Master code
            <input id="masterCode" type="password" autocomplete="off" required />
          </label>
          <button class="btn outline" type="submit">Enter Dashboard</button>
        </form>
      </div>
    </section>
  </main>

  <script>
    function showMessage(text, type) {
      const message = document.getElementById("message");
      message.textContent = text;
      message.className = "message " + type;
    }

    async function apiRequest(url, options) {
      const response = await fetch(url, {
        headers: { "Content-Type": "application/json" },
        credentials: "same-origin",
        ...options
      });

      const data = await response.json().catch(function () {
        return {};
      });

      if (!response.ok) {
        throw new Error(data.error || "Something went wrong.");
      }

      return data;
    }

    document.getElementById("loginForm").addEventListener("submit", async function (event) {
      event.preventDefault();

      try {
        await apiRequest("/api/login", {
          method: "POST",
          body: JSON.stringify({
            email: document.getElementById("email").value.trim().toLowerCase(),
            password: document.getElementById("password").value
          })
        });

        showMessage("Login successful. Taking you to your dashboard...", "success");

        window.setTimeout(function () {
          window.location.href = "dashboard.html";
        }, 500);
      } catch (error) {
        showMessage(error.message, "error");
      }
    });

    document.getElementById("forgotPassword").addEventListener("click", function () {
      showMessage("Password reset is not built yet. Create a new account or contact your site admin.", "error");
    });

    document.getElementById("masterForm").addEventListener("submit", async function (event) {
      event.preventDefault();

      try {
        await apiRequest("/api/master-login", {
          method: "POST",
          body: JSON.stringify({
            code: document.getElementById("masterCode").value
          })
        });

        showMessage("Master Mode accepted. Taking you to your dashboard...", "success");

        window.setTimeout(function () {
          window.location.href = "dashboard.html";
        }, 500);
      } catch (error) {
        showMessage(error.message, "error");
      }
    });
  </script>
</body>
</html>
